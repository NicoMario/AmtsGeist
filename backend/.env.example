# AmtsGeist Backend — Konfiguration (kopieren nach .env)

# Inferenz-Backend (Ollama nativ)
AMTSGEIST_OLLAMA_BASE_URL=http://localhost:11434
AMTSGEIST_REQUEST_TIMEOUT_S=120

# Modell-Kaskade
AMTSGEIST_SLM_MODEL=qwen2.5:3b
AMTSGEIST_LLM_MODEL=qwen2.5:7b
AMTSGEIST_ENABLE_CASCADE=true
AMTSGEIST_ESCALATION_CONFIDENCE_THRESHOLD=0.75

# Datenschutz (für Cloud-Burst-Profil auf true setzen)
AMTSGEIST_ENABLE_PII_PSEUDONYMIZATION=false

# Generierung
AMTSGEIST_TEMPERATURE=0.1

# Audit
AMTSGEIST_AUDIT_LOG_PATH=./audit.log.jsonl

# CORS — Ursprung des Outlook-Add-ins (JSON-Array)
AMTSGEIST_ALLOWED_ORIGINS=["https://localhost:3000"]
